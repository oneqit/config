
# tmux
_tmux_env() {
  export LANG=ko_KR.UTF-8
}

t()  { _tmux_env; tmux new "$@"; }              # (Optional) use -s <name>
ta() { _tmux_env; tmux attach "$@"; }          # use -t <name>
tl() { _tmux_env; tmux list-sessions "$@"; }
tc() { _tmux_env; tmux choose-session "$@"; }  # run inside tmux
tk() { _tmux_env; tmux kill-session "$@"; }   # use -t <name>
tK() { _tmux_env; tmux kill-server "$@"; }

# Auto-fallback TERM for SSH inside tmux (remote may lack tmux-256color terminfo)
ssh() {
  if [[ "$TERM" == tmux-* ]]; then
    TERM=xterm-256color command ssh "$@"
  else
    command ssh "$@"
  fi
}

# _tmux_split cmd_left cmd_right [cmd_right_bottom]
_tmux_split() {
  _tmux_env
  local cmd1="$1" cmd2="$2" cmd3="$3"
  local right_cmds=(
    send-keys "$cmd2" C-m \;
  )
  local select_left=(select-pane -L)
  if [[ -n "$cmd3" ]]; then
    right_cmds+=(split-window -v -l 50% \; send-keys "$cmd3" C-m \;)
    select_left=(select-pane -t '{left}')
  fi
  if [[ -n "$TMUX" ]]; then
    tmux split-window -h -l 50% \; \
      "${right_cmds[@]}" \
      "${select_left[@]}" \; \
      send-keys "$cmd1" C-m
  else
    tmux new-session \; \
      send-keys "$cmd1" C-m \; \
      split-window -h -l 50% \; \
      "${right_cmds[@]}" \
      "${select_left[@]}"
  fi
}

qlaude()  { _tmux_split "${1:-nvim}" "${2:-claude --allow-dangerously-skip-permissions}"; }
qodex()   { _tmux_split "${1:-nvim}" "${2:-codex}"; }
qopilot() { _tmux_split "${1:-nvim}" "${2:-copilot}"; }
qode()    { _tmux_split "${1:-nvim}" "${2:-claude --allow-dangerously-skip-permissions}" "${3:-copilot}"; }

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# qmux — 멀티 에이전트 병렬 실행
#
# 사용법:
#   qmux                           # 에이전트 선택 → 프롬프트 입력 → 병렬 실행
#   qmux "이 코드의 버그를 찾아줘"   # 프롬프트를 바로 넘기면 선택 후 즉시 실행
#   qmux prompt.md                  # 파일 경로를 넘기면 파일 내용을 프롬프트로 사용
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

qmux() {
  _tmux_env

  # ── 1) 설치된 에이전트 감지 ──────────────────────────
  local -a all_agents=(claude codex copilot gemini)
  local -a found=()

  for a in "${all_agents[@]}"; do
    if command -v "$a" &>/dev/null; then
      found+=("$a")
    fi
  done

  if (( ${#found[@]} == 0 )); then
    echo "\033[0;31m오류: 설치된 AI 에이전트가 없습니다 (claude, codex, copilot, gemini)\033[0m"
    return 1
  fi

  # ── 2) 에이전트 선택 (fzf 또는 수동) ────────────────
  local -a selected=()

  if command -v fzf &>/dev/null; then
    # fzf 멀티 선택: Tab으로 토글, Enter로 확정
    local choices
    choices=$(printf '%s\n' "${found[@]}" | fzf --multi \
      --header="에이전트 선택 (TAB: 토글, Enter: 확정, ESC: 취소)" \
      --prompt="에이전트> " \
      --no-input \
      --marker="✔ " \
      --height=10 --reverse --border)

    if [[ -z "$choices" ]]; then
      echo "취소됨"
      return 0
    fi
    while IFS= read -r line; do
      selected+=("$line")
    done <<< "$choices"
  else
    # fzf 없으면 번호 선택
    echo ""
    echo "\033[1m설치된 에이전트:\033[0m"
    local i=1
    for a in "${found[@]}"; do
      echo "  $i) $a"
      ((i++))
    done
    echo ""
    echo -n "사용할 에이전트 번호 (쉼표 구분, 예: 1,2): "
    read -r nums

    IFS=',' read -ra num_arr <<< "$nums"
    for n in "${num_arr[@]}"; do
      n=$(echo "$n" | tr -d ' ')
      if (( n >= 1 && n <= ${#found[@]} )); then
        selected+=("${found[$n]}")
      fi
    done
  fi

  if (( ${#selected[@]} == 0 )); then
    echo "\033[0;31m에이전트를 선택하지 않았습니다\033[0m"
    return 1
  fi

  # ── 3) 프롬프트 입력 ────────────────────────────────
  local prompt="${1:-}"

  if [[ -z "$prompt" ]]; then
    echo ""
    echo "\033[1m선택된 에이전트: \033[0;36m${(j:, :)selected}\033[0m"
    prompt=""
    vared -p "%B프롬프트: %b" prompt
    if [[ -z "$prompt" ]]; then
      echo "취소됨"
      return 0
    fi
  fi

  # 앞뒤 공백 제거
  prompt="${prompt#"${prompt%%[![:space:]]*}"}"
  prompt="${prompt%"${prompt##*[![:space:]]}"}"

  # ── 4) tmux 세션 구성 및 실행 ───────────────────────
  local n=${#selected[@]}
  local workdir
  workdir=$(pwd)

  # 프롬프트가 파일 경로면 그대로 사용, 아니면 임시 파일에 저장
  local tmpfile
  if [[ -f "$prompt" ]]; then
    tmpfile="$prompt"
  else
    tmpfile=$(mktemp "/tmp/qmux-XXXXXX")
    echo "$prompt" > "$tmpfile"
  fi

  # send-keys용 명령 문자열 생성
  _qmux_cmd() {
    local label="$1" agent="$2"
    local prompt_arg="cat '${tmpfile}'"
    if [[ "$agent" == "copilot" ]]; then
      echo "${agent} -i \"\$(${prompt_arg})\""
    elif [[ "$agent" == "claude" ]]; then
      echo "${agent} --allow-dangerously-skip-permissions \"\$(${prompt_arg})\""
    else
      echo "${agent} \"\$(${prompt_arg})\""
    fi
  }

  if [[ -n "$TMUX" ]]; then
    # ── 이미 tmux 안: _tmux_split과 동일한 패턴 ──
    # 현재 pane ID를 저장해두고, split 후 돌아올 때 사용
    local origin_pane
    origin_pane=$(tmux display-message -p '#{pane_id}')

    # 나머지 에이전트를 split으로 먼저 추가 (2번째부터)
    # select-layout 대신 비율 직접 계산 (다른 패인에 영향 안 줌)
    #   i=2 → (n-1)/n, i=3 → (n-2)/(n-1), ... 마지막 → 50%
    local split_cmds=()
    for ((i = 2; i <= n; i++)); do
      local agent="${selected[$i]}"
      local label="${$(echo "$agent"):u}"
      local pct=$(( (n - i + 1) * 100 / (n - i + 2) ))
      split_cmds+=(
        split-window -v -l "${pct}%" -c "$workdir" \;
        send-keys "$(_qmux_cmd "$label" "$agent")" C-m \;
      )
    done

    local first="${selected[1]}"
    local first_label="${$(echo "$first"):u}"

    tmux "${split_cmds[@]}" \
      select-pane -t "$origin_pane" \; \
      send-keys "$(_qmux_cmd "$first_label" "$first")" C-m

  else
    # ── tmux 밖: 새 세션 생성 ──
    local session="qmux-$(date +%H%M%S)"
    local first="${selected[1]}"
    local first_label="${$(echo "$first"):u}"

    tmux new-session -d -s "$session" -c "$workdir"
    tmux send-keys -t "$session" "$(_qmux_cmd "$first_label" "$first")" C-m

    for ((i = 2; i <= n; i++)); do
      local agent="${selected[$i]}"
      local label="${$(echo "$agent"):u}"
      local pct=$(( (n - i + 1) * 100 / (n - i + 2) ))
      tmux split-window -v -l "${pct}%" -t "$session" -c "$workdir"
      tmux send-keys "$(_qmux_cmd "$label" "$agent")" C-m
    done

    tmux select-pane -t "${session}:0.0"
    tmux attach -t "$session"
  fi
}
